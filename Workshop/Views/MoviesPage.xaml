<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MoviesMiniProject.Views.MoviesPage"
    BackgroundColor="#121212">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Search -->
        <SearchBar Grid.Row="0"
                   Placeholder="Search movie..."
                   TextChanged="OnSearchTextChanged"
                   Margin="10"
                   BackgroundColor="#1E1E1E"
                   TextColor="White"
                   PlaceholderColor="Gray"/>

        <!-- ปุ่มหมวดหมู่ -->
        <HorizontalStackLayout Grid.Row="1"
                               Spacing="10"
                               Padding="10">

            <Button Text="All" Clicked="AllClicked"/>
            <Button Text="Drama" Clicked="DramaClicked"/>
            <Button Text="Action" Clicked="ActionClicked"/>
            <Button Text="Crime" Clicked="CrimeClicked"/>
            <Button Text="SciFi" Clicked="SciFiClicked"/>
            <Button Text="Thriller" Clicked="ThrillerClicked"/>

        </HorizontalStackLayout>

        <!-- รายการหนัง -->
        <CollectionView Grid.Row="2"
                        x:Name="MoviesList"
                        SelectionMode="Single"
                        SelectionChanged="OnSelectionChanged">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Border Margin="12"
                            BackgroundColor="#1E1E1E"
                            Stroke="#333"
                            StrokeShape="RoundRectangle 15">

                        <Grid ColumnDefinitions="110,*">

                            <!-- Poster -->
                            <Image Source="{Binding Poster}"
                                   WidthRequest="110"
                                   HeightRequest="160"
                                   Aspect="AspectFill"/>

                            <!-- Info -->
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="6"
                                                 Padding="12">

                                <Label Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       FontSize="18"
                                       TextColor="White"/>

                                <Label Text="{Binding Year}"
                                       FontSize="14"
                                       TextColor="#BBBBBB"/>

                                <Label Text="{Binding Genre}"
                                       FontSize="13"
                                       TextColor="#9E9E9E"/>

                            </VerticalStackLayout>

                        </Grid>

                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>