<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:model="clr-namespace:MoviesMiniProject.Models"
    x:Class="MoviesMiniProject.Views.CategoryMoviesPage"
    Title="Movies by Category"
    BackgroundColor="#121212">

    <CollectionView
        x:Name="MoviesList"
        SelectionMode="Single"
        SelectionChanged="OnSelectionChanged">

        <CollectionView.ItemTemplate>

            <DataTemplate x:DataType="model:Movie">

                <Border
                    Margin="12"
                    BackgroundColor="#1E1E1E"
                    Stroke="#333">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15"/>
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="110,*">

                        <!-- Poster -->
                        <Image
                            Source="{Binding Poster}"
                            WidthRequest="110"
                            HeightRequest="160"
                            Aspect="AspectFill"/>

                        <!-- Movie Info -->
                        <VerticalStackLayout
                            Grid.Column="1"
                            Padding="12"
                            Spacing="6">

                            <Label
                                Text="{Binding Title}"
                                FontAttributes="Bold"
                                FontSize="18"
                                TextColor="White"/>

                            <Label
                                Text="{Binding Year, StringFormat='Year: {0}'}"
                                FontSize="14"
                                TextColor="#BBBBBB"/>

                            <Label
                                Text="{Binding Genre}"
                                FontSize="13"
                                TextColor="#9E9E9E"/>

                            <Label
                                Text="{Binding Rating, StringFormat='Rating: {0}/10'}"
                                FontSize="13"
                                TextColor="#FFD700"/>

                        </VerticalStackLayout>

                    </Grid>

                </Border>

            </DataTemplate>

        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentPage>